# --- Boîte mail des bounces ---
BOUNCE_EMAIL=bounces@example.com

# --- IMAP des bounces (uniquement en --mode poll, ex : Gandi) ---
# Gandi : BOUNCE_IMAP_HOST=mail.gandi.net   PORT=993
BOUNCE_IMAP_HOST=mail.gandi.net
BOUNCE_IMAP_PORT=993
BOUNCE_IMAP_USER=bounces@tondomaine.com
BOUNCE_IMAP_PASSWORD=changeme
BOUNCE_IMAP_FOLDER=INBOX
# Optionnel : dossier IMAP où déplacer les messages traités
# (laisser vide pour seulement les marquer comme lus)
BOUNCE_IMAP_PROCESSED_FOLDER=Processed
# Max messages traités par exécution (anti-tempête)
POLL_BATCH_LIMIT=200

# --- Seuils de traitement ---
# Nombre d'échecs cumulés avant inclusion dans to_be_paused.csv
SOFT_BOUNCE_THRESHOLD=5
# Zone d'alerte affichée dans le rapport (par défaut : SOFT_BOUNCE_THRESHOLD - 2)
SOFT_BOUNCE_WARNING=3
# Fenêtre théorique en jours (réservé pour usage futur)
SOFT_BOUNCE_WINDOW_DAYS=30

# --- IMAP de la boîte de réception classique (forwarding) ---
FORWARD_IMAP_HOST=mail.example.com
FORWARD_IMAP_PORT=993
FORWARD_IMAP_USER=contact@example.com
FORWARD_IMAP_PASSWORD=changeme
FORWARD_IMAP_FOLDER=INBOX

# --- LLM ---
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5

# --- SMTP du rapport ---
REPORT_SENDER=bounces@example.com
REPORT_RECIPIENT=info@example.com
REPORT_SMTP_HOST=smtp.example.com
REPORT_SMTP_PORT=587
REPORT_SMTP_USER=bounces@example.com
REPORT_SMTP_PASSWORD=changeme

# --- Webhook vers le CMS Cogiterra (optionnel) ---
# Si configuré, le rapport quotidien pousse aussi les 3 listes en JSON.
WEBHOOK_URL=
WEBHOOK_AUTH_TOKEN=
WEBHOOK_TIMEOUT=15

# --- Alertes Slack sur anomalies (optionnel) ---
# Pic > ALERT_SPIKE_MULTIPLIER × moyenne 7j → notification Slack
SLACK_WEBHOOK_URL=
ALERT_SPIKE_MULTIPLIER=2.0
ALERT_MIN_BASELINE=10

# --- Chemins (optionnels, valeurs par défaut acceptables) ---
# DB_PATH=data/bounces.db
# OUTPUT_DIR=output
# LOG_PATH=logs/bounce_processor.log
